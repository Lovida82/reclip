{
  "functions": {
    "api/info.py": {
      "runtime": "vercel-python@0.0.0",
      "maxDuration": 10
    },
    "api/extract.py": {
      "runtime": "vercel-python@0.0.0",
      "maxDuration": 10
    }
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "POST, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type" }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/api/info",
      "destination": "/api/info.py"
    },
    {
      "source": "/api/extract",
      "destination": "/api/extract.py"
    }
  ]
}
